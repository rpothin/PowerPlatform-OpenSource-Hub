{
  // This file is not used in compilation. It is here just for a nice editor experience.
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "resolveJsonModule": true,
    "jsx": "react",
    "ignoreDeprecations": "6.0",
    "types": ["jest", "react"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "docusaurus.config.ts",
    "sidebars.ts"
  ],
  "exclude": [
    "tests/user_interface/**"
  ]
}
