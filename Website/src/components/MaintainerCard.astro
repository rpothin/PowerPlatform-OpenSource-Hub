---
export interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="block rounded-xl border border-border bg-surface p-6 hover:border-primary hover:shadow-md transition-all duration-200 no-underline group">
  <div class="text-3xl mb-3">{icon}</div>
  <h3 class="text-lg font-semibold text-on-surface group-hover:text-primary mb-2">{title}</h3>
  <p class="text-sm text-on-surface-muted">{description}</p>
</a>
