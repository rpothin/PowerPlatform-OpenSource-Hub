{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHubRepositoriesDetails",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "createdAt",
      "description",
      "fullName",
      "hasIssues",
      "homepage",
      "isArchived",
      "language",
      "license",
      "name",
      "openIssuesCount",
      "owner",
      "updatedAt",
      "url",
      "codeOfConduct",
      "forkCount",
      "fundingLinks",
      "isSecurityPolicyEnabled",
      "isTemplate",
      "latestRelease",
      "primaryLanguage",
      "securityPolicyUrl",
      "stargazerCount",
      "watchers",
      "topics",
      "languages",
      "openedGoodFirstIssues",
      "hasGoodFirstIssues",
      "openedHelpWantedIssues",
      "hasHelpWantedIssues",
      "openedToContributionsIssues",
      "popularityScore",
      "_schemaVersion",
      "_generatedAt",
      "_workflowRunId"
    ],
    "additionalProperties": true,
    "properties": {
      "createdAt": { "type": "string" },
      "description": { "type": "string" },
      "fullName": { "type": "string" },
      "hasIssues": { "type": "boolean" },
      "homepage": { "type": ["string", "null"] },
      "isArchived": { "type": "boolean" },
      "language": { "type": "string" },
      "license": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "name": { "type": "string" },
      "openIssuesCount": { "type": "number" },
      "owner": {
        "type": "object",
        "required": ["login"],
        "properties": {
          "id": { "type": "string" },
          "is_bot": { "type": "boolean" },
          "login": { "type": "string" },
          "type": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "updatedAt": { "type": "string" },
      "url": { "type": "string" },
      "codeOfConduct": {
        "type": ["object", "null"],
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" },
          "url": { "type": "string" }
        }
      },
      "forkCount": { "type": "number" },
      "fundingLinks": { "type": "array" },
      "isSecurityPolicyEnabled": { "type": "boolean" },
      "isTemplate": { "type": "boolean" },
      "latestRelease": {
        "type": ["object", "null"],
        "properties": {
          "name": { "type": "string" },
          "tagName": { "type": "string" },
          "url": { "type": "string" },
          "publishedAt": { "type": "string" }
        }
      },
      "primaryLanguage": {
        "type": ["object", "null"],
        "properties": {
          "name": { "type": "string" }
        }
      },
      "securityPolicyUrl": { "type": ["string", "null"] },
      "stargazerCount": { "type": "number" },
      "watchers": {
        "type": "object",
        "required": ["totalCount"],
        "properties": {
          "totalCount": { "type": "number" }
        }
      },
      "topics": {
        "type": "array",
        "items": { "type": "string" }
      },
      "languages": {
        "type": "array",
        "items": { "type": "string" }
      },
      "openedGoodFirstIssues": { "type": "number" },
      "hasGoodFirstIssues": { "type": "boolean" },
      "openedHelpWantedIssues": { "type": "number" },
      "hasHelpWantedIssues": { "type": "boolean" },
      "openedToContributionsIssues": { "type": "number" },
      "popularityScore": { "type": "number" },
      "_schemaVersion": { "type": "string" },
      "_generatedAt": { "type": "string" },
      "_workflowRunId": { "type": "string" }
    }
  }
}
