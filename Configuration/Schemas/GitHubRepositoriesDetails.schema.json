{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "GitHubRepositoriesDetails.schema.json",
  "title": "GitHubRepositoriesDetails",
  "description": "Merged frontend repository artifact consumed by the website.",
  "type": "array",
  "items": {
    "allOf": [
      { "$ref": "GitHubRepositoryDefinitions.schema.json#/$defs/githubRepositoryFacts" },
      {
        "type": "object",
        "properties": {
          "repositoryId": { "$ref": "GitHubRepositoryDefinitions.schema.json#/$defs/repositoryId" }
        }
      },
      { "$ref": "GitHubRepositoryDefinitions.schema.json#/$defs/curatedRepositoryFields" },
      { "$ref": "GitHubRepositoryDefinitions.schema.json#/$defs/curationProvenance" }
    ]
  }
}
